 临床实施相关的研究数量', r1: '研究与真实临床实施相连接', r2: '研究与指南、政策或诊疗标准相关', r3: '教授住院医师 / Fellow / 医学生', r4: '提供 CME、工作坊或正式外部培训', r5: '开发课程或技能培训体系', r6: '教育成为临床实践传播的路径', e1: '有方案 / 路径 / 工作流程文件', e2: '有医院政策或内部批准记录', e3: '有 EMR / 医嘱集 / 实施截图或记录', e4: '有前后对比的量化数据', e5: '有采纳确认函 / 使用证明', e6: '有独立专家推荐信', e7: '有委员会 / 网络 / 公共卫生参与记录', e8: '有资助 / 机构支持 / QI 项目资料', labelEvidenceDesc: '重要指标或证据备注', evidencePlaceholder: '例如：等待时间减少 28%，结直肠癌筛查增加 19%，3 个站点采用该方案', scoreClinical: '临床强度', scoreSystem: '系统转化', scoreScale: '可扩展性', scorePublic: '国家重要性', scoreEvidence: '证据强度', reportProfile: '档案类型', reportExecutive: '核心摘要', reportStrength: '优势指标', reportRisk: '风险 / 薄弱点指标', reportStrategy: '优先策略说明', reservedTitle: '本部分保留给律师级案件结构分析。', reservedBody: '详细战略分析需要进一步的专业法律审查。', notAnalyzed: '尚未分析', profilePending: '点击生成分析后显示初步分类。', preAnalysis: '尚未分析。', noteText: '该结果用于医生 NIW 案件的初步结构判断。关键不在于这位医生是否只是“优秀医生”，而在于其临床工作是否已在医疗系统中形成结构并具有可扩展性。', ctaText: '基于您输入内容的完整分析需要进一步的专业评估。欢迎联系本所。', footerText: '本工具仅供教育及初步案件筛查使用，不构成法律意见。© Law Office of Hong-min Jun.'
      }
    };

    const $ = (id) => document.getElementById(id);
    const getNum = (id) => Number($(id).value || 0);
    const checkedCount = (selector) => document.querySelectorAll(selector + ':checked').length;
    const checkedValues = (selector) => Array.from(document.querySelectorAll(selector + ':checked')).map(el => el.value);
    let currentLang = 'en';

    function t(key) { return (i18n[currentLang] && i18n[currentLang][key]) || i18n.en[key] || key; }
    function cap5(n) { return Math.max(0, Math.min(5, Math.round(n))); }

    function localizeProfile(profile) {
      const map = {
        en: { 'Pure Clinical Performer':'Pure Clinical Performer','Physician-System Builder':'Physician-System Builder','Public Health Translator':'Public Health Translator','Clinical Innovator':'Clinical Innovator','Clinical Educator / Translator':'Clinical Educator / Translator','Mixed / Needs Structuring':'Mixed / Needs Structuring' },
        ko: { 'Pure Clinical Performer':'개별 임상 수행형','Physician-System Builder':'의료 시스템 구축형','Public Health Translator':'공중보건 번역형','Clinical Innovator':'임상 혁신형','Clinical Educator / Translator':'임상 교육 / 전파형','Mixed / Needs Structuring':'혼합형 / 구조화 필요' },
        zh: { 'Pure Clinical Performer':'个人临床执行型','Physician-System Builder':'医疗系统构建型','Public Health Translator':'公共卫生转化型','Clinical Innovator':'临床创新型','Clinical Educator / Translator':'临床教育 / 传播型','Mixed / Needs Structuring':'混合型 / 需重构' }
      };
      return map[currentLang][profile] || profile;
    }

    function scoreClinical() {
      let score = 1;
      const pv = getNum('patientVolume');
      const pr = getNum('procedureVolume');
      const cx = getNum('complexVolume');
      const usYears = getNum('usYears');
      const checks = checkedCount('.clinical');
      if (pv >= 1500 || pr >= 200 || cx >= 100) score += 1;
      if (checks >= 3) score += 1;
      if (checks >= 5) score += 1;
      if (usYears >= 3 || $('board').selectedIndex === 1 || $('fellowship').selectedIndex === 1) score += 1;
      return cap5(score);
    }
    function scoreSystem() {
      let score = 0;
      const checks = checkedValues('.system');
      score += Math.min(3, checks.length * 0.6);
      if (checks.includes('emr')) score += 1;
      if (checks.includes('hospitalwide')) score += 1;
      if (($('systemDesc').value || '').trim().length > 80) score += 0.5;
      return cap5(score);
    }
    function scoreScale() {
      let score = 0;
      const providers = getNum('providersInfluenced');
      const sites = getNum('sitesUsing');
      const external = getNum('externalInstitutions');
      const checks = checkedValues('.scale');
      score += Math.min(2, checks.length * 0.4);
      if (providers >= 5 || sites >= 2) score += 1;
      if (providers >= 20 || sites >= 4) score += 1;
      if (external >= 1 || checks.includes('external_adoption')) score += 1;
      if (checks.includes('sustainable')) score += 1;
      return cap5(score);
    }
    function scorePublic() {
      let score = 0;
      const checks = checkedValues('.public');
      score += Math.min(3, checks.length * 0.6);
      const disease = ($('diseaseArea').value || '').toLowerCase();
      const desc = (($('publicDesc').value || '') + ' ' + disease).toLowerCase();
      const keyWords = ['cardio','cancer','diabetes','opioid','mental','infection','screen','maternal','rural','underserved','chronic','심혈관','당뇨','암','정신','감염','예방','취약','慢','癌','糖尿病','感染','筛查'];
      if (keyWords.some(k => desc.includes(k))) score += 1;
      if (checks.includes('hpsa') && checks.includes('community')) score += 1;
      return cap5(score);
    }
    function scoreEvidence() {
      let score = 0;
      const checks = checkedValues('.evidence');
      score += Math.min(3, checks.length * 0.45);
      if (checks.includes('metrics')) score += 1;
      if (checks.includes('independent')) score += 1;
      if (checks.includes('adoption') || checks.includes('protocol_doc') || checks.includes('policy_doc')) score += 1;
      return cap5(score);
    }

    function getProfileType(s1, s2, s3, s4, s5) {
      if (s2 <= 1 && s3 <= 1) return ['Pure Clinical Performer', 'danger'];
      if (s2 >= 3 && s3 >= 3 && s4 >= 3 && s5 >= 3) return ['Physician-System Builder', 'ok'];
      if (s2 >= 3 && s4 >= 4) return ['Public Health Translator', 'ok'];
      if (s2 >= 3 && s3 >= 2) return ['Clinical Innovator', 'warn'];
      if (checkedCount('.research:checked') >= 3) return ['Clinical Educator / Translator', 'warn'];
      return ['Mixed / Needs Structuring', 'warn'];
    }

    function joinParts(parts) { return parts.filter(Boolean).join(' '); }

    function getClinicalNarrative(s1, name, specialty) {
      const checks = checkedValues('.clinical');
      const pv = getNum('patientVolume');
      const cx = getNum('complexVolume');
      if (currentLang === 'ko') {
        if (s1 >= 4) {
          if (checks.includes('high_risk') || checks.includes('rare') || cx >= 100) return `${name}은(는) ${specialty} 분야에서 고위험 또는 복합 중증 사례를 포함한 강한 임상 기반을 보여줍니다.`;
          if (pv >= 1500) return `${name}은(는) ${specialty} 분야에서 상당한 환자 진료 책임과 지속적인 임상 경험을 바탕으로 강한 임상 기반을 보여줍니다.`;
          return `${name}은(는) ${specialty} 분야에서 NIW 분석의 출발점이 될 수 있는 임상 기반을 보여줍니다.`;
        }
        if (s1 >= 3) return `${name}은(는) ${specialty} 분야에서 견실한 임상 배경을 가지고 있습니다.`;
        return `${name}은(는) ${specialty} 분야에서 기본적인 임상 배경을 보여줍니다.`;
      }
      if (currentLang === 'zh') {
        if (s1 >= 4) {
          if (checks.includes('high_risk') || checks.includes('rare') || cx >= 100) return `${name}在${specialty}领域展现出较强的临床基础，包括处理高风险或复杂病例的经验。`;
          if (pv >= 1500) return `${name}在${specialty}领域展现出较强的临床基础，体现在大量患者责任与持续执业经验上。`;
          return `${name}在${specialty}领域展现出可作为 NIW 分析起点的临床基础。`;
        }
        if (s1 >= 3) return `${name}在${specialty}领域具备扎实的临床背景。`;
        return `${name}在${specialty}领域具备基本的临床背景。`;
      }
      if (s1 >= 4) {
        if (checks.includes('high_risk') || checks.includes('rare') || cx >= 100) return `${name} demonstrates a strong clinical foundation in ${specialty}, including meaningful exposure to medically complex or higher-risk cases.`;
        if (pv >= 1500) return `${name} demonstrates a strong clinical foundation in ${specialty}, supported by substantial patient-care responsibility and sustained frontline practice.`;
        return `${name} demonstrates a strong clinical foundation in ${specialty}.`;
      }
      if (s1 >= 3) return `${name} appears to have a solid clinical background in ${specialty}.`;
      return `${name} shows a basic clinical background in ${specialty}.`;
    }

    function getSystemNarrative(s2, name) {
      const checks = checkedValues('.system');
      const desc = ($('systemDesc').value || '').trim();
      if (currentLang === 'ko') {
        if (s2 >= 4) return `${name}의 활동은 프로토콜, 경로, 또는 운영 방식과 같은 구조화된 시스템 요소로 번역된 것으로 보입니다.`;
        if (s2 >= 3) return `${name}은(는) 시스템 번역 요소를 일부 가지고 있는 것으로 보입니다.`;
        if (checks.length > 0 || desc.length > 0) return `${name}의 활동에는 시스템 지향적 요소의 초기 징후가 있습니다.`;
        return `현재 기록은 주로 개별 임상 활동에 가까워 보입니다.`;
      }
      if (currentLang === 'zh') {
        if (s2 >= 4) return `${name}的工作似乎已转化为方案、路径或运营流程等结构化系统要素。`;
        if (s2 >= 3) return `${name}似乎已具备一定的系统转化要素。`;
        if (checks.length > 0 || desc.length > 0) return `${name}的工作中已出现一些系统导向的早期迹象。`;
        return `目前记录主要仍接近于个人临床活动。`;
      }
      if (s2 >= 4) return `${name}'s work appears to have been translated into structured protocol, pathway, or workflow elements.`;
      if (s2 >= 3) return `${name} appears to have some meaningful system-translation evidence.`;
      if (checks.length > 0 || desc.length > 0) return `There are early signs of system-oriented activity in ${name}'s record.`;
      return `At present, the record primarily reflects individual clinical activity.`;
    }

    function getScaleNarrative(s3, name) {
      const providers = getNum('providersInfluenced');
      const sites = getNum('sitesUsing');
      const external = getNum('externalInstitutions');
      const checks = checkedValues('.scale');
      if (currentLang === 'ko') {
        if (s3 >= 4) {
          if (external >= 1 || checks.includes('external_adoption')) return `${name}의 기록은 외부 기관까지 도달한 확장성을 시사합니다.`;
          if (providers >= 20 || sites >= 4) return `${name}의 기록은 다수의 제공자 또는 다기관 사용을 통한 의미 있는 내부 확장성을 시사합니다.`;
          return `${name}의 기록은 일정 수준의 확장성 논리를 보여줍니다.`;
        }
        if (s3 >= 3) return `확장성 주장은 가능해 보입니다.`;
        return `${name}의 직접 진료를 넘어서는 확장성은 아직 제한적으로 보입니다.`;
      }
      if (currentLang === 'zh') {
        if (s3 >= 4) {
          if (external >= 1 || checks.includes('external_adoption')) return `${name}的记录显示其影响已扩展到外部机构。`;
          if (providers >= 20 || sites >= 4) return `${name}的记录显示其在多提供者或多站点中的内部扩展性。`;
          return `${name}的记录显示出一定程度的可扩展性。`;
        }
        if (s3 >= 3) return `可扩展性具有一定可信度。`;
        return `${name}超出直接诊疗范围的可扩展性目前仍较有限。`;
      }
      if (s3 >= 4) {
        if (external >= 1 || checks.includes('external_adoption')) return `The current intake suggests scalability beyond ${name}'s immediate practice setting.`;
        if (providers >= 20 || sites >= 4) return `The current intake suggests meaningful internal scalability through multi-provider or multi-site uptake.`;
        return `The current intake suggests a credible scalability argument.`;
      }
      if (s3 >= 3) return `Scalability is plausible on the current intake.`;
      return `Scalability beyond ${name}'s own direct patient care appears limited on the present record.`;
    }

    function getPublicNarrative(s4, name) {
      const checks = checkedValues('.public');
      const disease = $('diseaseArea').value || (currentLang === 'ko' ? '해당 건강 문제' : currentLang === 'zh' ? '相关健康问题' : 'the identified health issue');
      if (currentLang === 'ko') {
        if (s4 >= 4) return `${name}의 활동은 ${disease}를 포함한 더 넓은 미국 의료 문제와 연결될 수 있습니다.`;
        if (s4 >= 3) return `이 케이스는 더 넓은 미국의 질병 부담 또는 접근성 문제와 연결될 가능성이 있습니다.`;
        if (checks.includes('hpsa')) return `이 케이스는 의료 취약지역과의 관련성을 가집니다.`;
        return `국가적 중요성 연결은 아직 제한적으로 보입니다.`;
      }
      if (currentLang === 'zh') {
        if (s4 >= 4) return `${name}的工作可与包括 ${disease} 在内的更广泛美国医疗问题相联系。`;
        if (s4 >= 3) return `本案与更广泛的美国疾病负担或医疗可及性问题存在一定联系。`;
        if (checks.includes('hpsa')) return `本案与医疗短缺环境具有一定关联。`;
        return `国家重要性的连接目前仍较有限。`;
      }
      if (s4 >= 4) return `From a national-importance perspective, ${name}'s work is credibly connected to broader U.S. healthcare concerns, including ${disease}.`;
      if (s4 >= 3) return `From a national-importance perspective, the case has a plausible connection to broader U.S. health burdens or access concerns.`;
      if (checks.includes('hpsa')) return `The case has some shortage-setting relevance.`;
      return `The national-importance framing appears limited on the current record.`;
    }

    function getEvidenceNarrative(s5) {
      if (currentLang === 'ko') {
        if (s5 >= 4) return `증거 구조는 비교적 강한 편으로 보입니다.`;
        if (s5 >= 3) return `증거 구조는 일정 부분 활용 가능해 보입니다.`;
        return `증거 구조는 현재 더 보강이 필요해 보입니다.`;
      }
      if (currentLang === 'zh') {
        if (s5 >= 4) return `证据结构相对较强。`;
        if (s5 >= 3) return `证据结构具有一定可用性。`;
        return `证据结构目前仍需进一步加强。`;
      }
      if (s5 >= 4) return `The evidence profile appears comparatively strong.`;
      if (s5 >= 3) return `The evidence profile appears potentially usable at a preliminary level.`;
      return `The evidence profile appears to need further strengthening.`;
    }

    function applyLanguage(lang) {
      currentLang = lang;
      document.documentElement.lang = lang === 'zh' ? 'zh' : lang;
      document.title = t('pageTitle');
      document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));

      const textMap = {
        '.brand h1':'brandTitle','.brand .sub':'brandSub','#analyzeBtn':'btnAnalyze','#printBtn':'btnPrint','#sampleBtn':'btnSample','#resetBtn':'btnReset',
        '.grid .card:first-child .card-head h2':'intakeTitle','.grid .card:first-child .card-head p':'intakeDesc','.grid .card:last-child .card-head h2':'assessTitle','.grid .card:last-child .card-head p':'assessDesc',
        'details.section:nth-of-type(1) > summary':'sec1','details.section:nth-of-type(2) > summary':'sec2','details.section:nth-of-type(3) > summary':'sec3','details.section:nth-of-type(4) > summary':'sec4','details.section:nth-of-type(5) > summary':'sec5','details.section:nth-of-type(6) > summary':'sec6','details.section:nth-of-type(7) > summary':'sec7',
        '.score-box:nth-child(1) .k':'scoreClinical','.score-box:nth-child(2) .k':'scoreSystem','.score-box:nth-child(3) .k':'scoreScale','.score-box:nth-child(4) .k':'scorePublic','.score-box:nth-child(5) .k':'scoreEvidence',
        '.report:nth-of-type(1) h3':'reportProfile','.report:nth-of-type(2) h3':'reportExecutive','.report:nth-of-type(3) h3':'reportStrength','.report:nth-of-type(4) h3':'reportRisk','.report:nth-of-type(5) h3':'reportStrategy','#noteText':'noteText','#ctaText':'ctaText','#footerText':'footerText'
      };
      Object.entries(textMap).forEach(([selector, key]) => { const el = document.querySelector(selector); if (el) el.textContent = t(key); });

      const setLabelForId = (id, key) => { const el = document.getElementById(id); if (el && el.parentElement && el.parentElement.querySelector('label')) el.parentElement.querySelector('label').textContent = t(key); };
      setLabelForId('name','labelName'); setLabelForId('specialty','labelSpecialty'); setLabelForId('subspecialty','labelSubspecialty'); setLabelForId('position','labelPosition'); setLabelForId('institution','labelInstitution'); setLabelForId('setting','labelSetting'); setLabelForId('license','labelLicense'); setLabelForId('board','labelBoard'); setLabelForId('fellowship','labelFellowship'); setLabelForId('usYears','labelUsYears'); setLabelForId('foreignYears','labelForeignYears'); setLabelForId('diseaseArea','labelDiseaseArea'); setLabelForId('patientVolume','labelPatientVolume'); setLabelForId('procedureVolume','labelProcedureVolume'); setLabelForId('complexVolume','labelComplexVolume'); setLabelForId('systemDesc','labelSystemDesc'); setLabelForId('providersInfluenced','labelProvidersInfluenced'); setLabelForId('sitesUsing','labelSitesUsing'); setLabelForId('externalInstitutions','labelExternalInstitutions'); setLabelForId('publicDesc','labelPublicDesc'); setLabelForId('publications','labelPublications'); setLabelForId('citations','labelCitations'); setLabelForId('guidelineStudies','labelGuidelineStudies'); setLabelForId('evidenceDesc','labelEvidenceDesc');

      const setCheckText = (selector, key) => { const el = document.querySelector(selector + ' span'); if (el) el.textContent = t(key); };
      setCheckText('.clinical[value="high_risk"]','c1'); setCheckText('.clinical[value="multidisciplinary"]','c2'); setCheckText('.clinical[value="rare"]','c3'); setCheckText('.clinical[value="triage"]','c4'); setCheckText('.clinical[value="critical"]','c5'); setCheckText('.clinical[value="consulted"]','c6');
      setCheckText('.system[value="protocol"]','s1'); setCheckText('.system[value="pathway"]','s2'); setCheckText('.system[value="screening"]','s3'); setCheckText('.system[value="followup"]','s4'); setCheckText('.system[value="emr"]','s5'); setCheckText('.system[value="hospitalwide"]','s6');
      setCheckText('.scale[value="internal_spread"]','sc1'); setCheckText('.scale[value="cross_dept"]','sc2'); setCheckText('.scale[value="external_adoption"]','sc3'); setCheckText('.scale[value="training"]','sc4'); setCheckText('.scale[value="committee"]','sc5'); setCheckText('.scale[value="sustainable"]','sc6');
      setCheckText('.public[value="burden"]','p1'); setCheckText('.public[value="prevention"]','p2'); setCheckText('.public[value="access"]','p3'); setCheckText('.public[value="cost"]','p4'); setCheckText('.public[value="hpsa"]','p5'); setCheckText('.public[value="community"]','p6');
      setCheckText('.research[value="implementation_research"]','r1'); setCheckText('.research[value="guideline"]','r2'); setCheckText('.research[value="resident_edu"]','r3'); setCheckText('.research[value="cme"]','r4'); setCheckText('.research[value="curriculum"]','r5'); setCheckText('.research[value="translation"]','r6');
      setCheckText('.evidence[value="protocol_doc"]','e1'); setCheckText('.evidence[value="policy_doc"]','e2'); setCheckText('.evidence[value="emr_doc"]','e3'); setCheckText('.evidence[value="metrics"]','e4'); setCheckText('.evidence[value="adoption"]','e5'); setCheckText('.evidence[value="independent"]','e6'); setCheckText('.evidence[value="committee_doc"]','e7'); setCheckText('.evidence[value="grant"]','e8');

      $('setting').options[0].text = t('optSelect'); $('setting').options[1].text = t('optAcademic'); $('setting').options[2].text = t('optCommunity'); $('setting').options[3].text = t('optPrivate'); $('setting').options[4].text = t('optPublicHealth'); $('setting').options[5].text = t('optMultisite'); $('setting').options[6].text = t('optUnderserved');
      $('license').options[0].text = t('optSelect'); $('license').options[1].text = t('optFull'); $('license').options[2].text = t('optTraining'); $('license').options[3].text = t('optPending');
      $('board').options[0].text = t('optNo'); $('board').options[1].text = t('optYes'); $('fellowship').options[0].text = t('optNo'); $('fellowship').options[1].text = t('optYes');
      $('evidenceDesc').placeholder = t('evidencePlaceholder');
      $('diseaseArea').placeholder = currentLang === 'ko' ? '예: 심혈관질환, 당뇨, 암 스크리닝' : currentLang === 'zh' ? '例如：心血管疾病、糖尿病、癌症筛查' : 'e.g. cardiovascular disease, diabetes, cancer screening';
      document.querySelectorAll('.reserved-box strong').forEach(el => el.textContent = t('reservedTitle'));
      document.querySelectorAll('.reserved-box').forEach(el => { el.lastChild.textContent = '\n              ' + t('reservedBody'); });

      if ($('profilePill').dataset.state !== 'analyzed') {
        $('profilePill').textContent = t('notAnalyzed');
        $('profileSummary').textContent = t('profilePending');
        $('executiveSummary').textContent = t('preAnalysis');
      }
    }

    function analyze() {
      const s1 = scoreClinical(), s2 = scoreSystem(), s3 = scoreScale(), s4 = scorePublic(), s5 = scoreEvidence();
      $('scoreClinical').textContent = s1; $('scoreSystem').textContent = s2; $('scoreScale').textContent = s3; $('scorePublic').textContent = s4; $('scoreEvidence').textContent = s5;
      const [profile, tone] = getProfileType(s1, s2, s3, s4, s5);
      $('profilePill').className = 'pill ' + tone;
      $('profilePill').textContent = localizeProfile(profile);
      $('profilePill').dataset.state = 'analyzed';
      const name = $('name').value || (currentLang === 'ko' ? '이 의사' : currentLang === 'zh' ? '该医生' : 'This physician');
      const specialty = $('specialty').value || (currentLang === 'ko' ? '해당 전문분야' : currentLang === 'zh' ? '相关专业领域' : 'the stated specialty');
      const institution = $('institution').value || (currentLang === 'ko' ? '현재 기관' : currentLang === 'zh' ? '当前机构' : 'the current institution');

      if (currentLang === 'ko') {
        $('profileSummary').textContent = `${name}은(는) ${specialty} 분야에서 ${institution} 소속으로 현재 ${localizeProfile(profile)} 유형으로 보는 것이 적절합니다.`;
      } else if (currentLang === 'zh') {
        $('profileSummary').textContent = `${name} 目前在 ${institution} 的 ${specialty} 领域，较适合归类为 ${localizeProfile(profile)}。`;
      } else {
        $('profileSummary').textContent = `${name} in ${specialty} at ${institution} is presently best viewed as: ${profile}.`;
      }

      $('executiveSummary').textContent = joinParts([
        getClinicalNarrative(s1, name, specialty),
        getSystemNarrative(s2, name),
        getScaleNarrative(s3, name),
        getPublicNarrative(s4, name),
        getEvidenceNarrative(s5)
      ]);
    }

    function resetForm() {
      document.querySelectorAll('input, textarea, select').forEach(el => {
        if (el.type === 'checkbox') el.checked = false;
        else if (el.tagName === 'SELECT') el.selectedIndex = 0;
        else el.value = '';
      });
      ['scoreClinical','scoreSystem','scoreScale','scorePublic','scoreEvidence'].forEach(id => $(id).textContent = '0');
      $('profilePill').className = 'pill warn'; $('profilePill').textContent = t('notAnalyzed'); delete $('profilePill').dataset.state;
      $('profileSummary').textContent = t('profilePending'); $('executiveSummary').textContent = t('preAnalysis');
    }

    function loadSample() {
      resetForm();
      $('name').value = 'Dr. Sample Physician'; $('specialty').value = 'Internal Medicine / Preventive Cardiology'; $('subspecialty').value = 'Cardiometabolic Risk Reduction'; $('position').value = 'Hospitalist and Quality Improvement Lead'; $('institution').value = 'Sample Regional Health System'; $('setting').selectedIndex = 5; $('license').selectedIndex = 1; $('board').selectedIndex = 1; $('fellowship').selectedIndex = 1; $('usYears').value = '6'; $('foreignYears').value = '4'; $('diseaseArea').value = 'cardiovascular disease, diabetes, underserved population'; $('patientVolume').value = '1800'; $('complexVolume').value = '220'; $('systemDesc').value = 'Developed a cardiometabolic screening and referral workflow that shortened specialist referral time and standardized follow-up across clinics.'; $('providersInfluenced').value = '35'; $('sitesUsing').value = '4'; $('externalInstitutions').value = '1'; $('publicDesc').value = 'The work addresses major U.S. burdens in cardiovascular disease and diabetes by improving early risk identification and preventive care access.'; $('publications').value = '9'; $('citations').value = '118'; $('guidelineStudies').value = '3'; $('evidenceDesc').value = 'Referral time reduced by 31%; workflow adopted at 4 clinics.';
      ['high_risk','multidisciplinary','triage','consulted'].forEach(v => document.querySelector(`.clinical[value="${v}"]`).checked = true);
      ['protocol','pathway','screening','followup','emr','hospitalwide'].forEach(v => document.querySelector(`.system[value="${v}"]`).checked = true);
      ['internal_spread','cross_dept','external_adoption','training','committee','sustainable'].forEach(v => document.querySelector(`.scale[value="${v}"]`).checked = true);
      ['burden','prevention','access','cost','hpsa','community'].forEach(v => document.querySelector(`.public[value="${v}"]`).checked = true);
      ['implementation_research','guideline','resident_edu','cme','curriculum','translation'].forEach(v => document.querySelector(`.research[value="${v}"]`).checked = true);
      ['protocol_doc','policy_doc','emr_doc','metrics','adoption','independent','committee_doc','grant'].forEach(v => document.querySelector(`.evidence[value="${v}"]`).checked = true);
      analyze();
    }

    document.querySelectorAll('.lang-btn').forEach(btn => btn.addEventListener('click', () => applyLanguage(btn.dataset.lang)));
    $('analyzeBtn').addEventListener('click', analyze);
    $('resetBtn').addEventListener('click', resetForm);
    $('sampleBtn').addEventListener('click', loadSample);
    $('printBtn').addEventListener('click', () => window.print());
    applyLanguage('en');
  </script>
</body>
</html>
